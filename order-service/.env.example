## order-service environment variables
## Copy to `.env` and keep only one block active.

## -------- LOCAL --------

PORT=8083
DB_URL=jdbc:mysql://localhost:3306/orders_db
DB_USERNAME=root
DB_PASSWORD=
JWT_SECRET=LOCAL_DEV_SECRET_CHANGE_ME
EUREKA_DEFAULT_ZONE=http://localhost:8761/eureka/


## -------- PRODUCTION (uncomment when deploying) --------

# PORT=8083
# DB_URL=jdbc:mysql://production-host:3306/orders_db?useSSL=false&allowPublicKeyRetrieval=true
# DB_USERNAME=prod_user
# DB_PASSWORD=prod_password
# JWT_SECRET=SUPER_SECURE_RANDOM_KEY
# EUREKA_DEFAULT_ZONE=https://exocommerce-backend.onrender.com/eureka/
